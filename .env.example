# Copy this file to .env and fill in your values.

# Optional — enables Alpha Vantage price fetching (free tier: 25 req/day)
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Optional overrides (defaults shown)
# PORT=3001
# DB_PATH=/data/wealth.db

# Scheduled price refresh (runs inside the server process via node-cron)
# Default: 18:00 Mon-Fri Amsterdam time. Standard cron syntax.
# PRICE_FETCH_CRON=0 18 * * 1-5

# Timezone for the cron schedule. Defaults to Amsterdam time.
# TZ=Europe/Amsterdam
